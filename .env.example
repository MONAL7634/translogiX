# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/translogix

# BetterAuth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional live operations integrations
# Use the same Google Cloud key for server Routes API and browser Maps JS,
# or split them into restricted server/browser keys in production.
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
